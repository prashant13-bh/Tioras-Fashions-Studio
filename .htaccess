# Hostinger Node.js Application Configuration
RewriteEngine On

# Disable DirectoryIndex to prevent serving old index.html files
DirectoryIndex disabled

# ─── CRITICAL FIX ───
# Proxy ALL requests to the Node.js application unconditionally.
# This ensures that old static files (index.html, legacy JS/CSS) on the server
# are NEVER served directly. Next.js handles all routing internally.
RewriteRule ^(.*)$ http://127.0.0.1:3000/$1 [P,L]

# Prevent caching of HTML pages to avoid "old landing page" issues
<FilesMatch "\.(html|php)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
</FilesMatch>

# Allow caching of static assets (Next.js adds content hashes, so immutable is safe)
<FilesMatch "\.(css|js|jpg|jpeg|png|gif|ico|svg|woff|woff2|webp|avif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
